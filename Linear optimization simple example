        "#@title Ridership Model\n",
        "\n",
        "# Import necessary libraries\n",
        "import ipywidgets as widgets\n",
        "from IPython.display import display, Math\n",
        "\n",
        "# Coefficients for the linear program\n",
        "objective_coeffs = [400, 125, 60, 40]  # Coefficients of the objective function\n",
        "constraint_coeffs = [20, 8, 4, 3]      # Coefficients of the constraint\n",
        "constraint_bound = 500                 # Constraint bound\n",
        "\n",
        "# Create float sliders for the decision variables x1, x2, x3, and x4\n",
        "x1_slider = widgets.FloatSlider(value=0.0, min=0.0, max=30.0, step=0.1, description=\"Heavy Rail x₁\")\n",
        "x2_slider = widgets.FloatSlider(value=0.0, min=0.0, max=70.0, step=0.1, description=\"Light Rail x₂\")\n",
        "x3_slider = widgets.FloatSlider(value=0.0, min=0.0, max=130.0, step=0.1, description=\"BRT        x₃\")\n",
        "x4_slider = widgets.FloatSlider(value=0.0, min=0.0, max=170.0, step=0.1, description=\"Bus        x₄\")\n",
        "\n",
        "# Output widget for displaying equations\n",
        "output = widgets.Output()\n",
        "\n",
        "# Function to dynamically update and display equations\n",
        "def update_equations(x1, x2, x3, x4):\n",
        "    with output:\n",
        "        # Clear previous output\n",
        "        output.clear_output(wait=True)\n",
        "\n",
        "        # Compute objective function value\n",
        "        Z = (objective_coeffs[0] * x1 +\n",
        "             objective_coeffs[1] * x2 +\n",
        "             objective_coeffs[2] * x3 +\n",
        "             objective_coeffs[3] * x4)\n",
        "\n",
        "        # Compute constraint function value\n",
        "        constraint_value = (constraint_coeffs[0] * x1 +\n",
        "                            constraint_coeffs[1] * x2 +\n",
        "                            constraint_coeffs[2] * x3 +\n",
        "                            constraint_coeffs[3] * x4)\n",
        "\n",
        "        # Determine constraint status\n",
        "        if constraint_value <= constraint_bound:\n",
        "            constraint_status = r\"\\textcolor{green}{Satisfied}\"\n",
        "        else:\n",
        "            constraint_status = r\"\\textcolor{red}{Violated}\"\n",
        "\n",
        "        # Create LaTeX strings\n",
        "        objective_latex = rf\"Maximize \\,Ridership \\quad 400x_1 + 125x_2 + 60x_3 + 40x_4 = \" \\\n",
        "                          rf\"400({x1:.1f}) + 125({x2:.1f}) + 60({x3:.1f}) + 40({x4:.1f}) = {Z:.1f}\"\n",
        "\n",
        "        constraint_latex = rf\"\\quad \\quad s. t.  \\quad  20x_1 + 8x_2 + 4x_3 + 3x_4 \\leq {constraint_bound}\" \\\n",
        "                           rf\" \\quad \\text{{where }} 20({x1:.1f}) + 8({x2:.1f}) + 4({x3:.1f}) + 3({x4:.1f}) = {constraint_value:.1f}\" \\\n",
        "                           rf\" \\quad \\textbf{{{constraint_status}}}\"\n",
        "\n",
        "        # Display equations\n",
        "        display(Math(objective_latex))\n",
        "        display(Math(constraint_latex))\n",
        "\n",
        "# Create an interactive widget\n",
        "interactive_display = widgets.interactive(update_equations,\n",
        "                                          x1=x1_slider,\n",
        "                                          x2=x2_slider,\n",
        "                                          x3=x3_slider,\n",
        "                                          x4=x4_slider)\n",
        "\n",
        "# Arrange equations above sliders\n",
        "layout = widgets.VBox([output, x1_slider, x2_slider, x3_slider, x4_slider])\n",
        "\n",
        "# Display the layout\n",
        "display(layout)\n",
        "\n",
        "# Initialize the equations\n",
        "update_equations(0.0, 0.0, 0.0, 0.0)"
      ]
    }
  ]
